<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="HabitSnap.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">@dimen/button_corner_radius</item>
        <item name="android:layout_height">@dimen/button_height</item>
        <item name="android:textSize">@dimen/text_size_medium</item>
        <item name="backgroundTint">@color/purple_dark</item>
    </style>

    <style name="HabitSnap.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="cornerRadius">@dimen/button_corner_radius</item>
        <item name="strokeColor">@color/purple_dark</item>
        <item name="android:textColor">@color/purple_dark</item>
    </style>

    <style name="HabitSnap.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">@dimen/card_corner_radius</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="cardBackgroundColor">@color/card_white</item>
    </style>
</resources>